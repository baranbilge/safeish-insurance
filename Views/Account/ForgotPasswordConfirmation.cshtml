@{
    ViewData["Title"] = "Şifre Sıfırlama Bağlantısı Gönderildi";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-lg text-center p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
            </div>
            <h3 class="mb-3">E-posta Gönderildi</h3>
            <p class="text-muted">
                Eğer sistemimizde kayıtlı bir e-posta adresi girdiyseniz, şifre sıfırlama bağlantısını içeren bir e-posta alacaksınız. Lütfen gelen kutunuzu (ve spam klasörünü) kontrol edin.
            </p>
            
            @if (TempData["ResetLink"] != null)
            {
                <div class="alert alert-info mt-4 text-start">
                    <strong>Test Ortamı Notu:</strong> SMTP ayarları yapılandırılmadığı için sıfırlama linki aşağıdadır:<br />
                    <a href="@TempData["ResetLink"]" class="alert-link" style="word-break: break-all;">@TempData["ResetLink"]</a>
                </div>
            }

            <div class="mt-4">
                <a asp-action="Login" class="btn btn-outline-primary px-4">Giriş Yap</a>
            </div>
        </div>
    </div>
</div>
