<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Safeish Sigorta</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: -0.5px; }
        .nav-link { font-weight: 500; }
        .bg-primary { background-color: #0d6efd !important; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo_cropped.png" alt="Safeish Logo" height="50" style="border-radius: 8px;" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/#hero">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/#sigortalar">Sigortalar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/#anlasmali-kurumlar">Anlaşmalı Kurumlar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/#finansal-danismanlik">Finansal Danışmanlık</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/#iletisim">İletişim</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link px-3 text-light">Merhaba, @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 btn btn-light text-primary ms-2 rounded-pill fw-bold" asp-area="" asp-controller="Account" asp-action="Logout">Çıkış Yap</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 btn btn-light text-primary bg-white rounded-pill fw-bold" asp-area="" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 btn btn-light text-primary bg-white ms-2 rounded-pill fw-bold" asp-area="" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1 py-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <button type="button" class="btn btn-primary rounded-circle shadow d-flex align-items-center justify-content-center" id="btn-back-to-top" style="position: fixed; bottom: 30px; right: 30px; display: none; z-index: 1000; width: 50px; height: 50px; transition: opacity 0.3s;">
        <i class="bi bi-arrow-up fs-4"></i>
    </button>

    <footer class="border-top footer text-muted bg-white mt-auto py-4">
        <div class="container text-center">
            &copy; 2026 - Safeish Sigorta A.Ş. - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Gizlilik Politikası</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Scroll to top button logic
        let mybutton = document.getElementById("btn-back-to-top");
        window.onscroll = function () {
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                mybutton.style.display = "flex";
                mybutton.style.opacity = "1";
            } else {
                mybutton.style.opacity = "0";
                setTimeout(() => {
                    if(document.body.scrollTop <= 300 && document.documentElement.scrollTop <= 300) {
                        mybutton.style.display = "none";
                    }
                }, 300);
            }
        };

        mybutton.addEventListener("click", function() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
